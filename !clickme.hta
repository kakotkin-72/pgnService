<!doctype html>
<html>
<head>
<meta http-equiv="content-type" content="text/html;charset=utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=8">
<meta http-equiv="MSThemeCompatible" content="yes">
<meta name="author" content="(С) 2026 Владимир Какоткин">

<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Cache-Control" content="no-cache,no-store,must-revalidate">
<meta http-equiv="Expires" content="0">

<title>pgnService - Справка</title>

<!------------------------------------------------------------->
<!-- Блок: Первичная инициализация -->

<script language = "JScript">

var m_width = 800, m_height = 500;

function winHide() {
  window.moveTo(-3000, -3000);
}

winHide();
window.resizeTo(m_width, m_height);

if (!document.documentMode || (document.documentMode != 8)) {
  var msg =
    "Это HTML-приложение требует поддержки режима IE=8.\n" +
    "This HTML Application requires support for IE=8 mode.";

  alert(msg);
  self.close();
}

window.onerror = function(msg, url, num) {
  var title = "Произошла ошибка во время работы приложения.\n";

  // сработает уже на дальнейшей проверке синтаксиса
  alert(title + "Описание: " + msg + "\nСтрока: #" + num);
  self.close();
};

</script>

<!------------------------------------------------------------->
<!-- Блок: Глобальные свойства -->

<hta:application
  Id              = "HTA"
  ApplicationName = "!clickme"
  Icon            = "pgnService.ico"
  Border          = "thick"
  BorderStyle     = "normal"
  Caption         = "yes"
  MaximizeButton  = "yes"
  MinimizeButton  = "yes"
  Scroll          = "no"
  Selection       = "no"
  SingleInstance  = "yes"
  ShowInTaskbar   = "yes"
  SysMenu         = "yes"
  WindowState     = "normal"
/>

<style>
  html, body {
    overflow: hidden;
  }
</style>

<!------------------------------------------------------------->
<!-- Блок: Системные переменные -->

<script language = "JScript">

var m_app = new ActiveXObject("Shell.Application");
var m_shl = new ActiveXObject("WScript.Shell");

</script>

<!------------------------------------------------------------->
<!-- Блок: Системная библиотека -->

<script language = "JScript">

function winCenter() {
  window.moveTo(
    (screen.width  - m_width)  / 2,
    (screen.height - m_height) / 2);
}

function winIsMaximized() {
  var doc = window.document.documentElement;
  var cliw = doc.clientWidth;
  var clih = doc.clientHeight;

  var scrw = screen.availWidth;
  var scrh = screen.availHeight;

  var ret =
    (Math.abs(scrw - cliw) < 32) &&
    (Math.abs(scrh - clih) < 32);

  return ret;
}

function txtQuote(text) {
  if (!text) return '""';

  var pure = text.replace(/^"+|"+$/g, "");
  pure = pure.replace(/"/g, '""');

  return '"' + pure + '"';
}

function dlgMsg(text) {
  text = text.replace(/&/g,  "&amp;");
  text = text.replace(/"/g,  "&quot;");
  text = text.replace(/'/g,  "&#39;");
  text = text.replace(/</g,  "&lt;");
  text = text.replace(/>/g,  "&gt;");
  text = text.replace(/\\/g, "\\\\");
  text = text.replace(/  /g, " &nbsp;");
  text = text.replace(/(\r\n|\n|\r)/g, "<br>");

  var div = document.createElement("div");

  div.style.font       = "9pt Tahoma";
  div.style.lineHeight = "140%";
  div.style.width      = "192pt";
  div.style.position   = "absolute";
  div.style.visibility = "hidden";
  div.innerHTML        = text;

  document.body.appendChild(div);
  var htxt = div.scrollHeight;
  document.body.removeChild(div);

  var hdlg = ((htxt > 32) ? htxt : 32) + 70;
  hdlg = ((hdlg * 0.75) | 0) + "pt";

  var title = "Сообщение";

  var html =
    "<html><head>"                                              +
    "<title>" + title + "</title>"                              +
    "<meta http-equiv='content-type'"                           +
    "  content='text/html;charset=utf-8'>"                      +
    "<meta http-equiv='MSThemeCompatible' content='Yes'>"       +
    "<style>"                                                   +
    "  html,body{"                                              +
    "    background-color:ButtonFace;color:ButtonText;"         +
    "    margin:0;padding:9pt;overflow:hidden}"                 +
    "  td,button{font:9pt Tahoma}"                              +
    "  button{width:68pt;height:20pt;}"                         +
    " .btnrect{"                                                +
    "    position:absolute;left:9pt;bottom:14pt;"               +
    "    width:100%;text-align:center}"                         +
    "</style>"                                                  +
    "</head><body>"                                             +
    "<table"                                                    +
    "  cellpadding='0' cellspacing='0' style='width:100%'>"     +
    "  <tr>"                                                    +
    "    <td"                                                   +
    "      style='position:relative;width:42pt;height:34pt;"    +
    "      text-align:left;vertical-align:middle;"              +
    "      background-color:transparent;padding:0;'>"           +
    "      <font face='Webdings'"                               +
    "        style='color:#FFFFFF;font-size:32pt;"              +
    "        line-height:34pt;display:block;width:34pt;"        +
    "        text-align:center;background-color:transparent;"   +
    "        margin:0;padding:0;'>n</font>"                     +
    "      <font face='Webdings'"                               +
    "        style='color:#3399FF;font-size:32pt;"              +
    "        line-height:34pt;display:block;width:34pt;"        +
    "        text-align:center;background-color:transparent;"   +
    "        position:absolute;top:1pt;left:0;height:100%;"     +
    "        margin:0;padding:0;'>i</font>"                     +
    "    </td>"                                                 +
    "    <td style='line-height:140%;text-align:left;"          +
    "      vertical-align:top;'>"                        + text +
    "    </td>"                                                 +
    "  </tr>"                                                   +
    "</table>"                                                  +
    "<div class='btnrect'>"                                     +
    "  <button onclick='window.close()'>OK</button>"            +
    "</div>"                                                    +
    "<s" + "cript>"                                             +
    "  window.document.onkeydown=function(){"                   +
    "    if(window.event.keyCode==27)window.close();};"         +
    "</s" + "cript>"                                            +
    "</body></html>";

  var opts =
    "dialogWidth:263pt;dialogHeight:" + hdlg + ";center:yes;" +
    "resizable:no;scroll:no;status:no;help:no;";

  html = "javascript:document.write(\"" + html + "\")";
  window.showModalDialog(html, window, opts);
}

function winOnError(msg, url, num) {
  var title = "Произошла ошибка во время работы приложения.\n";

  try {
    var req = new ActiveXObject("MSXML2.XMLHTTP");
    req.open("GET", url, false);
    req.send();

    if ((req.status == 200) || (req.status == 0)) {
      var list = req.responseText.split(/\r?\n/);
      var item = list[num - 1];

      var log =
        title                     + "\n"   +
        "Описание:\n    "   + msg + "\n"   +
        "Файл (URL):\n    " + url + "\n"   +
        "Cтрока: #"         + num + "\n\n" +
        "Текст строки (но это неточно):\n" +
        "- - -\n"                          +
        item + "\n"                        +
        "- - -";

      alert(log); // dlgMsg - нельзя
    }
  } catch(e) {
    alert(title + "Описание: " + msg + "\nСтрока: #" + num);
  }

  self.close();
};

function docMouseWheel() {
  var evt = window.event, cmod = evt.ctrlKey;
  if (!cmod) return;

  // блокировка IE-масштабирования
  evt.returnValue = false;
  return false;
}

function docOnClick() {
  var tag = window.event.srcElement;
  while (tag && tag.tagName.toUpperCase() != "A")
    tag = tag.parentElement;

  if (!tag) return true;

  var atr = tag.getAttributeNode("onclick");
  if (atr && atr.specified) return true;

  atr = tag.getAttribute("href");
  if (!atr || atr == "#") return true;

  if (atr.indexOf("#") == 0) {
    atr = atr.substring(1);
    tag =
      document.getElementById(atr) ||
      document.getElementsByName(atr);

    if (!tag || (("length" in tag) && (tag.length == 0))) {
      dlgMsg("Не удалось совершить переход на:\n" + atr);
      return false;
    }

    return true;
  }
  else {
    try {
      m_shl.Run(txtQuote(tag.href), 1, false);
    } catch(e) {
      dlgMsg("Не удалось найти файл или адрес:\n" + tag.href);
    }
  }

  return false;
}

</script>

<!------------------------------------------------------------->
<!-- Ты их нашел :) -->

</head>
<body>

<!------------------------------------------------------------->
<!-- Блок: Живой поиск -->

<style>
  span.srhlink {
    color: #000;
    background-color: #ff0;
    font-size: inherit;
    font-weight: bold;
    text-decoration: none;
    cursor: pointer;
  }
  span.srhlink:hover {
    text-decoration: underline;
  }
</style>

<script language = "JScript">

var SRH_HIBRD = "5pt solid #00f";
var SRH_HIPAD = "8pt";
var m_srhtop  = 25;
var m_srhbase = [];   // запись: type, node, text, lbrd, lpad
var m_srhbox  = null; // контейнер c тегами
var m_srhctl  = null; // поле ввода текста для поиска
var m_srhold  = "";

function srhInit(box, inp) {
  if (m_srhctl) return;

  var ctl = document.getElementById(box);
  if (ctl && document.getElementById(inp))
    m_srhbox = box, m_srhctl = inp;
  else
    return;

  var items = ctl.childNodes;

  // предварительный сбор тегов и никакой магии
  for (var i = 0; i < items.length; ++i) {
    var child = items[i], txt = "", rec;

    if (child.nodeType == 1) { // нормальные видимые теги
      var name = child.tagName.toUpperCase();
      var id = child.id.toUpperCase();

      // адаптация: здесь можно расширить поиск
      var use =
        (name == "H1") || (name == "H2") || (name == "H3") ||
        (name == "P")  || (name == "DIV");

      // адаптация: здесь можно ограничить
      var ign = (id == "BANNER") || (id == "FOOTER");

      txt = child.innerHTML.replace(/^\s+|\s+$/g, '');
      if ((use && !ign) && (txt.length > 0)) {
        var pleft =
          child.style.paddingLeft ||
          child.currentStyle.paddingLeft;

        var bleft = child.style.borderLeft;

        if (!bleft) { // ньюансы IE8
          var cur = child.currentStyle;
          var bst = cur.borderLeftStyle;

          // сборка правильного инлайнового стиля
          if (bst && bst != "none") {
            bleft =
              cur.borderLeftWidth + " " + bst + " " +
              cur.borderLeftColor;
          }
        }

        rec = {
          type: 1,
          node: child,
          text: child.innerHTML,
          lbrd: bleft,
          lpad: pleft
        };

        m_srhbase.push(rec);
      }
      else
        m_srhbase.push({ type: -1, node: child }); // левые теги
    }
    else
    if (child.nodeType == 3) { // сырой текст без тегов
      txt = child.nodeValue.replace(/^\s+|\s+$/g, '');
      if (txt.length < 1) continue;

      rec = { type: 3, node: child, text: child.nodeValue };
      m_srhbase.push(rec);
    }
  }
}

function srhLive() {
  if (!m_srhctl) return;

  var ctl = document.getElementById(m_srhctl);
  var rng = document.body.createTextRange();
  var smpl = ctl.value.toLowerCase();
  var live = smpl.length > 1;

  if (m_srhold == smpl) return;
  m_srhold = smpl;

  for (var i = 0; i < m_srhbase.length; ++i) {
    var rec = m_srhbase[i];

    if (rec.type == -1) { // левые теги
      rec.node.style.display = live ? "none" : "";
      continue;
    }
    else
    if (rec.type == 3) { // сырой текст
      rec.node.nodeValue = live ? "" : rec.text;
      continue;
    }

    // попутное восстановление в инлайны
    rec.node.style.borderLeft  = rec.lbrd;
    rec.node.style.paddingLeft = rec.lpad;
    rec.node.style.display     = "";
    rec.node.innerHTML         = rec.text;

    if (!live) continue;

    var txt = rec.node.innerText || rec.node.textContent;
    var idx = txt.toLowerCase().indexOf(smpl);

    if (idx == -1) {
      rec.node.style.display = "none"; // скрыть неподходящий тег
      continue;
    }

    // индикатор для найденного блока
    rec.node.style.borderLeft  = SRH_HIBRD;
    rec.node.style.paddingLeft = SRH_HIPAD;

    // вклейка подсвеченного текста как псевдоссылки для перехода
    rng.moveToElementText(rec.node);

    while (rng.findText(smpl, 0, 0)) {
      var lnk =
        "<span" +
        " class   = 'srhlink'"  +
        " onclick = 'srhClick(" + i + ")'>" +
        rng.text +
        "</span>";

      rng.pasteHTML(lnk);
      rng.collapse(false);
    }
  }

  ctl = document.getElementById(m_srhbox);
  ctl.scrollTop = 0;
}

function srhClear(fcs) {
  if (!m_srhctl) return;
  m_srhold = "";

  document.getElementById(m_srhctl).value = "";
  if (fcs) document.getElementById(fcs).focus();

  for (var i = 0; i < m_srhbase.length; ++i) {
    var rec = m_srhbase[i];

    if (rec.type == 1) { // нормальные теги
      rec.node.style.backgroundColor = "";

      rec.node.innerHTML         = rec.text;
      rec.node.style.borderLeft  = rec.lbrd;
      rec.node.style.paddingLeft = rec.lpad;
    }
    else
    if (rec.type == 3) { // сырой текст
      rec.node.nodeValue = rec.text;
      continue;
    }

    rec.node.style.display = ""; // и левые тоже покажутся
  }
}

function srhClick(idx) {
  if (!m_srhctl) return;
  srhClear(m_srhctl);

  var tag = m_srhbase[idx].node;
  if (!tag) return;

  var ctl = document.getElementById(m_srhbox);
  ctl.scrollTop = tag.offsetTop - m_srhtop;
}

function srhClickFirst() {
  if (!m_srhctl) return;

  var ctl = document.getElementById(m_srhctl);
  if (ctl.value.length < 1) return;

  var idx = -1;

  for (var i = 0; (i < m_srhbase.length) && (idx == -1); ++i)
  if (m_srhbase[i].node.style.display != "none")
    idx = i;

  if (idx != -1) srhClick(idx);
}

</script>

<!------------------------------------------------------------->
<!-- Блок: История -->

<script language = "JScript">

var m_hstlock = true;
var m_hstbase = [];

function hstReset() {
  m_hstlock = false;
  m_hstbase = ["#"];
}

function hstAdd(hash) {
  if (!hash) return;

  if (m_hstbase[m_hstbase.length - 1] != hash)
    m_hstbase.push(hash);
}

function hstBack() {
  m_hstlock = true;

  if (m_hstbase.length > 1)
    m_hstbase.pop();

  hash = m_hstbase[m_hstbase.length - 1];
  if (hash != "#")
    window.location.hash = hash;
  else
    jumpTop(); // адаптация: т.к. # это контекст всей страницы

  m_hstlock = false;
}

function hstTracker() {
  if (m_hstlock) return;

  var hash = window.location.hash;
  if (hash) hstAdd(hash);
};

function hstInit() {
  hstReset();
  window.onhashchange = hstTracker;
}

</script>

<!------------------------------------------------------------->
<!-- Блок: Масштабирование тега -->

<script language = "JScript">

var m_zmtmlt = 1.0, m_zmtmin = 0.5, m_zmtmax = 1.5;
var m_zmtorg = 10.0, m_zmtctl = null;

function zmtInit(box, min, max) {
  if (m_zmtctl) return;

  // box - это контейнер, у детей размер шрифтов через em
  var ctl = document.getElementById(box);
  if (!ctl) return;

  if (min > max) max = [min, min = max][0];
  if ((min > 1.0) || (max < 1.0)) return;

  m_zmtctl = box, m_zmtmin = min, m_zmtmax = max;

  var txt =
    ctl.style.fontSize                              ||
    (ctl.currentStyle && ctl.currentStyle.fontSize) ||
    "10.0pt";

  txt = txt.replace(",", ".").replace(/[^\d\.]/g, "");
  m_zmtorg = parseFloat(txt);
}

function zmtApply() {
  if (!m_zmtctl) return;

  var ctl = document.getElementById(m_zmtctl);
  var size = m_zmtorg * m_zmtmlt;
  size = (Math.round(size * 10) / 10) + "pt";

  ctl.style.fontSize = size; // инлайновый размер

  // ньюансы IE8
  var list = ctl.getElementsByTagName("th");
  for (var i = 0; i < list.length; ++i)
    list[i].style.fontSize = size;

  list = ctl.getElementsByTagName("td");
  for (var i = 0; i < list.length; ++i)
    list[i].style.fontSize = size;
}

function zmtInc() {
  if (!m_zmtctl) return;

  m_zmtmlt += 0.1;
  m_zmtmlt = Math.min(Math.max(m_zmtmlt, m_zmtmin), m_zmtmax);

  m_zmtmlt = Math.round(m_zmtmlt * 10) / 10;
  zmtApply();
}

function zmtDec() {
  if (!m_zmtctl) return;

  m_zmtmlt -= 0.1;
  m_zmtmlt = Math.min(Math.max(m_zmtmlt, m_zmtmin), m_zmtmax);

  m_zmtmlt = Math.round(m_zmtmlt * 10) / 10;
  zmtApply();
}

function zmtReset() {
  if (!m_zmtctl) return;

  m_zmtmlt = 1.0;
  zmtApply();
}

function zmtWheel() {
  if (!m_zmtctl) return;

  var evt = window.event, cmod = evt.ctrlKey;
  if (!cmod) return;

  (evt.wheelDelta > 0) ? zmtInc() : zmtDec();
}

</script>

<!------------------------------------------------------------->
<!-- Прикладные функции -->

<script language = "JScript">

var RSZ_MINW = 500, RSZ_MINH = 400;
var m_rsztick = null;

function onResize() {
  clearTimeout(m_rsztick);

  m_rsztick = setTimeout(function() {
    var de = document.documentElement;
    var bd = document.body;

    var cliw = de.clientWidth  || bd.clientWidth;
    var clih = de.clientHeight || bd.clientHeight;

    var extw = window.outerWidth  || (cliw + 16);
    var exth = window.outerHeight || (clih + 39);
    var need = false;

    if (cliw < RSZ_MINW) {
      need = true;
      extw =
        window.outerWidth                     ?
        (RSZ_MINW + window.outerWidth - cliw) :
        (RSZ_MINW + 16);
    }

    if (clih < RSZ_MINH) {
      need = true;
      exth =
        window.outerHeight                     ?
        (RSZ_MINH + window.outerHeight - clih) :
        (RSZ_MINH + 39);
    }

    if (need) window.resizeTo(extw, exth);
  }, 50);
}

function onKeyDown() {
  var evt  = window.event, code = evt.keyCode;
  var cmod = evt.ctrlKey,  amod = evt.altKey;
  var left = evt.ctrlLeft, fcs  = evt.srcElement;

  var quit =
    (amod && (code == 88))  || // Alt-X
    (cmod && (code == 81))  || // Ctlr-Q
    (cmod && (code == 115));   // Ctlr-F4

  if (quit) { self.close(); return; }

  if (cmod && (code == 107 || code == 187)) { // Ctr +
    evt.keyCode = 0;
    evt.returnValue = false;

    // блокировка IE-масштабирования немедленным возвратом 100%
    try { m_shl.SendKeys("^0"); } catch(e) {} // LCtrl-0
    if (left) return false;

    zmtInc();
    return false;
  }
  else
  if (cmod && (code == 109 || code == 189)) { // Ctr -
    evt.keyCode = 0;
    evt.returnValue = false;

    // блокировка IE-масштабирования немедленным возвратом 100%
    try { m_shl.SendKeys("^0"); } catch(e) {} // LCtrl-0
    if (left) return false;

    zmtDec();
    return false;
  }
  else
  if (cmod && (code == 48 || code == 96)) { // Ctr-0
    evt.keyCode = 0;
    evt.returnValue = false;

    // чтобы не спотыкаться о свой же LCtrl-0
    if (left) return false;

    zmtReset();
    return false;
  }
  else
  if (code == 116) { // F5 - жесткое обновление
    evt.keyCode = 0;
    evt.returnValue = false;

    var url = window.location.href.split('#')[0];
    window.location.href = url + '#' + (new Date().getTime());
    window.location.reload(true); // HTA Reset

    return false;
  }
  else
  if (code == 27) { // Esc - Выход
    evt.keyCode = 0;
    evt.returnValue = false;

    var ctl = document.getElementById("ctlInp");
    if (ctl && ctl.value.length > 0)
      srhClear("ctlInp");
    else
      self.close();

    return false;
  }
  else
  if (code == 122) { // F11 - развернуть/восстановить
    evt.keyCode = 0;
    evt.returnValue = false;

    if (winIsMaximized()) {
      m_shl.SendKeys("%( )"); // Alt-Space - оконное меню
      m_shl.SendKeys("{ENTER}");
    }
    else {
      m_shl.SendKeys("%( )");
      m_shl.SendKeys("{UP}{UP}{ENTER}");
    }

    return false;
  }
  else
  if (code == 8) { // Backspace - переход назад по истории
    if ((fcs.id != "ctlInp") || (fcs.value.length < 1)) {
      evt.keyCode = 0;
      evt.returnValue = false;

      hstBack();
      return false;
    }
  }
  else
  if (code == 13) { // Enter
    if ((fcs.id == "ctlInp") && (fcs.value.length > 0)) {
      evt.keyCode = 0;
      evt.returnValue = false;

      srhClickFirst();
      return false;
    }
  }
  else
  if (/^(33|34|35|36|38|40)$/.test(code)) { // кроме Left и Right
    var leave = (fcs.id == "ctlInp") && (fcs.value.length < 1);
    if (leave) document.getElementById("content").focus();
  }
  else
  if (!cmod && !amod)
  {
    var mix = // буквы и цифры
      (code >= 48 && code <= 90) ||
      (code >= 96 && code <= 105);

    if (mix && (fcs.id != "ctlInp"))
      document.getElementById("ctlInp").focus();
  }
}

function jumpTop(fcs) {
  srhClear();
  hstAdd("#");

  var ctl = document.getElementById("content");
  if (!ctl) return;

  ctl.scrollTop = 0;

  ctl = document.getElementById(fcs);
  if (ctl) ctl.focus();
}

function openRU64() {
  var lnk = "ru64.sibhost.ru";
  m_app.ShellExecute("http://" + lnk, "", "", "open", 1);
}

function openWiki() {
  var lnk = "ru.wikipedia.org/wiki/Portable_Game_Notation";
  m_app.ShellExecute("https://" + lnk, "", "", "open", 1);
}

</script>

