window.onload = function() {
  window.onerror = winOnError;

  srhInit("content", "ctlInp");
  zmtInit("content", 0.6, 2.5);
  hstInit();

  document.getElementById("content").
    attachEvent("onmousewheel", zmtWheel); // адаптация

  document.onclick = docOnClick;
  document.onmousewheel = docMouseWheel;
  document.onkeydown = onKeyDown;

  window.onresize = onResize;
  winCenter();

  document.getElementById("ctlInp").focus();
};

</script>

