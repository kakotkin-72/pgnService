<!-- Стили интерфейса -->

<style>
  * {
    font-family: "Tahoma", sans-serif !important;
    font-size: 9pt;
    font-weight: normal;
    font-style: normal;
    font-variant: normal;
    line-height: normal;
  }
  body {
    color: ButtonText;
    background-color: ButtonFace;
    margin: 12pt;
    padding: 0;
  }
  table {
    width: 100%;
    border: none;
    border-collapse: collapse;
  }
  th, td {
    border: none;
    padding: 0;
    vertical-align: top;
  }
  input[type="checkbox"], input[type="radio"] {
    width: 10pt;
    height: 10pt;
    vertical-align: middle;
  }
  button {
    width: 68pt;
    height: 21pt;
    margin: 0;
    padding: 0;
  }
  a, a:visited, a:active {
    color: #00f !important;
    text-decoration: none;
    cursor: pointer;
  }
  a:hover {
    text-decoration: underline;
  }
  /* для отладки верстки удалить 2 последних символа *//*
  table, th, td {
    outline: 1px solid black !important;
  }
  /* для отладки */
</style>

<!------------------------------------------------------------->
<!-- Элементы интерфейса -->

<table>
  <tr>
    <td style = "width:75%;padding-bottom:4pt;">
      <label>
        Параметры обработки PGN-файлов:
      </label>
    </td>
    <td
      align = "right"
      style = "padding-bottom:4pt;">
      <a href = "#"
        onclick = "onHelp(); return false;">
        Справка
      </a>
      &nbsp;
      <a href = "#"
        onclick = "lngToggle(!m_langrus); return false;">
        Рус/Eng
      </a>
    </td>
  </tr>

  <tr style = "height:16pt;">
    <td colspan = "2" style = "vertical-align:top;"><hr></td>
  </tr>
</table>

<table>
  <tr>
    <td style = "width:50%;">
      <table>
        <tr>
          <td style = "width:19pt;padding-top:1pt;">
            <input
              type     = "checkbox"
              id       = "ctlSet"
              onchange = "m_cfgset=this.checked">
          </td>
          <td style = "padding-top:2pt;">
            <label for = "ctlSet">
              Использовать тег SetUp
            </label>
          </td>
        </tr>

        <tr>
          <td style = "padding-top:1pt;">
            <input
              type     = "checkbox"
              id       = "ctlEco"
              onchange = "m_cfgeco=this.checked">
          </td>
          <td style = "padding-top:2pt;">
            <label for = "ctlEco">
              Оставлять тег ECO
            </label>
          </td>
        </tr>

        <tr>
          <td style = "padding-top:1pt;">
            <input
              type     = "checkbox"
              id       = "ctlElo"
              onchange = "m_cfgelo=this.checked">
          </td>
          <td style = "padding-top:2pt;">
            <label for = "ctlElo">
              Оставлять WhiteElo и BlackElo
            </label>
          </td>
        </tr>

        <tr>
          <td style = "padding-top:1pt;">
            <input
              type     = "checkbox"
              id       = "ctlFid"
              onchange = "m_cfgfid=this.checked">
          </td>
          <td style = "padding-top:2pt;">
            <label for = "ctlFid">
              Оставлять WhiteFideId и BlackFideId
            </label>
          </td>
        </tr>

        <tr>
          <td style = "padding-top:1pt;">
            <input
              type     = "checkbox"
              id       = "ctlFix"
              onchange = "m_cfgfix=this.checked">
          </td>
          <td style = "padding-top:2pt;">
            <label for = "ctlFix">
              Сжимать неопределенную дату
            </label>
          </td>
        </tr>
      </table>
    </td>

    <td style="padding-left:4pt;">
      <table>
        <tr style = "height:27pt;">
          <td style = "width:40pt;padding-top:3pt;">
            <table>
              <tr>
                <td>
                  <input
                    type       = "text"
                    class      = "spinint"
                    style      = "width:40pt;"
                    id         = "ctlSize"
                    value      = "60"
                    onblur     = "spinBlur('ctlSize',20,180)"
                    onkeypress = "spinPress()"
                    onkeydown  =
                      "spinDown('ctlSize',10,20,180)">
                </td>

                <td>
                  <button
                    class       = "spinbtn"
                    onmouseup   = "spinStop()"
                    onmouseout  = "spinStop()"
                    onmousedown =
                      "spinStart('ctlSize',+10,20,180)"
                    ondblclick =
                      "spinDbl('ctlSize',+10,20,180)">
                  ▲</button>
                  <button
                    class       = "spinbtn"
                    onmouseup   = "spinStop()"
                    onmouseout  = "spinStop()"
                    onmousedown =
                      "spinStart('ctlSize',-10,20,180)"
                    ondblclick =
                      "spinDbl('ctlSize',-10,20,180)">
                  ▼</button>
                </td>
              </tr>
            </table>
          </td>
          <td style = "padding: 2pt 0 6pt 6pt;">
            <label>
              Ширина форматирования<br>
              (20 - 180 символов)
            </label>
          </td>
        </tr>

        <tr style = "height:27pt;">
          <td style = "padding-top:3pt;">
            <table>
              <tr>
                <td>
                  <input
                    type       = "text"
                    class      = "spinint"
                    style      = "width:40pt;"
                    id         = "ctlCount"
                    value      = "100"
                    onblur     = "spinBlur('ctlCount',2,10000)"
                    onkeypress = "spinPress()"
                    onkeydown  =
                      "spinDown('ctlCount',100,2,10000)">
                </td>

                <td>
                  <button
                    class       = "spinbtn"
                    onmouseup   = "spinStop()"
                    onmouseout  = "spinStop()"
                    onmousedown =
                      "spinStart('ctlCount',+100,2,10000)"
                    ondblclick =
                      "spinDbl('ctlCount',+100,2,10000)">
                  ▲</button>
                  <button
                    class       = "spinbtn"
                    onmouseup   = "spinStop()"
                    onmouseout  = "spinStop()"
                    onmousedown =
                      "spinStart('ctlCount',-100,2,10000)"
                    ondblclick =
                      "spinDbl('ctlCount',-100,2,10000)">
                  ▼</button>
                </td>
              </tr>
            </table>
          </td>
          <td style = "padding: 2pt 0 6pt 6pt;">
            <label>
              Количество первых партий<br>
              для сортировок (до 10,000)
            </label>
          </td>
        </tr>
      </table>

      <table>
        <tr style = "text-align:right;">
          <td style = "height:24pt;vertical-align:bottom;">
            <button onclick = "onReset()">
              Сбросить
            </button>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<table>
  <tr style = "height:13pt;">
    <td colspan = "2" style = "vertical-align:bottom;"><hr></td>
  </tr>

  <tr style = "height:23pt;">
    <td style = "width:19pt;padding-top:1pt;">
      <input
        type     = "checkbox"
        id       = "ctlRes"
        onchange = "m_resout=this.checked">
    </td>
    <td style = "padding-top:2pt;">
      <label for = "ctlRes">
        Открывать итоговый файл в Блокноте
      </label>
    </td>
  </tr>
</table>

<table>
  <tr>
    <td style = "width:50%;padding:4pt 4pt 4pt 0;">
      <button
        style   = "width:100%;height:27pt;"
        onclick = "onStart('luaClean')">
          Только чистка тегов от мусора
      </button>
    </td>

    <td style = "width:50%;padding: 4pt 0 4pt 4pt;">
      <button
        style   = "width:100%;height:27pt;"
        onclick = "onStart('luaShuffle')">
          Перемешать, чтобы не скушно
      </button>
    </td>
  </tr>

  <tr>
    <td style = "width:50%;padding: 4pt 4pt 4pt 0;">
      <button
        style   = "width:100%;height:27pt;"
        onclick = "onStart('luaFormat')">
          Компактное форматирование
      </button>
    </td>

    <td style = "width:50%;padding: 4pt 0 4pt 4pt;">
      <button
        style   = "width:100%;height:27pt;"
        onclick = "onStart('luaNormalize')">
          Сортировать всё скучно обратно
      </button>
    </td>
  </tr>
</table>
</body>
</html>
